######################## Custom Aliases ########################

alias vim='nvim'
alias sv='source venv/bin/activate'
alias de='deactivate'
alias sbrc='source ~/.bashrc; source ~/.bash_aliases'

alias ls='ls --color=auto --group-directories-first'
alias ll='ls -l --color=auto --group-directories-first'
alias grep='grep --color=auto'
alias tree='tree -L 2'

alias gs='git status'
alias ga='git add'
alias gc='git commit'
